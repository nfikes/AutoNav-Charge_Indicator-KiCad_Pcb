{
  "permissions": {
    "deny": [
      "Edit(./BEHAVIOR.md)",
      "Write(./BEHAVIOR.md)",
      "NotebookEdit(./BEHAVIOR.md)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/protect-behavior.sh"
          }
        ]
      }
    ]
  }
}
